*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# IDEs and editor configs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

